# DayZ Manager - environment configuration
# Copy this file to ".env" and adjust as needed.

# HTTP/WebSocket port for the backend
PORT=8765

# Network host the backend binds to (0.0.0.0 = LAN-accessible)
HOST=127.0.0.1

# Optional basic auth credentials for the dashboard (leave blank to disable)
ADMIN_USER=
ADMIN_PASSWORD=

# A long random string used to sign session tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Path to a local SteamCMD installation. Leave empty to auto-install into ./steamcmd
STEAMCMD_PATH=

# Optional: override default project paths (absolute paths recommended on Windows)
# DATA_DIR=
# SERVERS_DIR=
# LOGS_DIR=
# CONFIGS_DIR=
